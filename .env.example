# Database passwords
POSTGRES_PASSWORD=change_me_postgres_password
NEO4J_PASSWORD=change_me_neo4j_password

# Together.ai API
TOGETHER_API_KEY=your_together_api_key
TOGETHER_MODEL_PLANNER=deepseek-ai/DeepSeek-V3
TOGETHER_MODEL_EXECUTOR=deepseek-ai/DeepSeek-V3
TOGETHER_MODEL_EMBEDDING=togethercomputer/m2-bert-80M-8k-retrieval

# Discord bot
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_private_channel_id

# Google API (Gmail & Calendar)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Sync API (for remote coding sessions from cognitex-sync client)
# Generate with: cognitex generate-sync-key
SYNC_API_KEY=change_me_to_random_string_for_sync_client
